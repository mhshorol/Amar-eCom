{
  "entities": {
    "user": {
      "title": "User",
      "description": "System users and team members",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "staff"] },
        "active": { "type": "boolean" },
        "permissions": { "$ref": "#/entities/userPermissions" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "active"]
    },
    "userPermissions": {
      "title": "User Permissions",
      "description": "Module-level access permissions",
      "type": "object",
      "properties": {
        "dashboard": { "type": "boolean" },
        "pos": { "type": "boolean" },
        "orders": { "type": "boolean" },
        "inventory": { "type": "boolean" },
        "crm": { "type": "boolean" },
        "suppliers": { "type": "boolean" },
        "logistics": { "type": "boolean" },
        "tasks": { "type": "boolean" },
        "finance": { "type": "boolean" },
        "hr": { "type": "boolean" },
        "team": { "type": "boolean" },
        "settings": { "type": "boolean" },
        "reports": { "type": "boolean" }
      }
    },
    "order": {
      "title": "Order",
      "description": "Sales orders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "number" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "customer": {
      "title": "Customer",
      "description": "Client information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "warehouse": {
      "title": "Warehouse",
      "description": "Storage locations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "product": {
      "title": "Product",
      "description": "Inventory items",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stockLevel": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "variant": {
      "title": "Product Variant",
      "description": "Specific variations of a product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stockLevel": { "type": "number" }
      }
    },
    "task": {
      "title": "Task",
      "description": "Internal team tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "assignedTo": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "activityLog": {
      "title": "Activity Log",
      "description": "Audit trail of system actions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "module": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "notification": {
      "title": "Notification",
      "description": "In-app notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "recipients": { "type": "array", "items": { "type": "string" } },
        "readBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "account": {
      "title": "Account",
      "description": "Financial accounts (Bank, Cash, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "transaction": {
      "title": "Transaction",
      "description": "Financial records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "supplier": {
      "title": "Supplier",
      "description": "Vendor information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "courier_config": {
      "title": "Courier Config",
      "description": "Courier API settings",
      "type": "object",
      "properties": {
        "isActive": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "purchaseBatch": {
      "title": "Purchase Batch",
      "description": "Inventory stock batches for valuation (FIFO/LIFO)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "variantId": { "type": "string" },
        "quantity": { "type": "number", "description": "Current quantity in this batch" },
        "originalQuantity": { "type": "number" },
        "unitCost": { "type": "number" },
        "supplierId": { "type": "string" },
        "warehouseId": { "type": "string" },
        "purchaseDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" }
      }
    },
    "stockLedger": {
      "title": "Stock Ledger",
      "description": "Detailed log of every stock movement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "variantId": { "type": "string" },
        "type": { "type": "string", "enum": ["purchase", "sale", "return", "adjustment", "transfer", "damaged"] },
        "quantity": { "type": "number", "description": "Positive for stock in, negative for stock out" },
        "unitCost": { "type": "number" },
        "totalValue": { "type": "number" },
        "warehouseId": { "type": "string" },
        "referenceId": { "type": "string", "description": "Order ID, Purchase ID, etc." },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "performanceMetric": {
      "title": "Performance Metric",
      "description": "Employee performance scores and KPIs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "kpiScore": { "type": "number" },
        "metrics": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "user", "description": "System users" },
    "orders": { "schema": "order", "description": "Sales records" },
    "customers": { "schema": "customer", "description": "Client records" },
    "products": { "schema": "product", "description": "Product catalog" },
    "variants": { "schema": "variant", "description": "Product variations" },
    "inventory": { "schema": "object", "description": "Stock levels" },
    "tasks": { "schema": "task", "description": "Task management" },
    "activityLogs": { "schema": "activityLog", "description": "Audit logs" },
    "notifications": { "schema": "notification", "description": "User notifications" },
    "warehouses": { "schema": "warehouse", "description": "Locations" },
    "accounts": { "schema": "account", "description": "Financial accounts" },
    "transactions": { "schema": "transaction", "description": "Financial entries" },
    "suppliers": { "schema": "supplier", "description": "Vendors" },
    "purchaseOrders": { "schema": "object", "description": "Inventory purchases" },
    "supplierPayments": { "schema": "object", "description": "Vendor payments" },
    "inventoryLogs": { "schema": "object", "description": "Stock history" },
    "categories": { "schema": "object", "description": "Product categories" },
    "brands": { "schema": "object", "description": "Product brands" },
    "rma_requests": { "schema": "object", "description": "Returns" },
    "couriers": { "schema": "object", "description": "Shipping partners" },
    "deliveries": { "schema": "object", "description": "Order shipments" },
    "courier_configs": { "schema": "courier_config", "description": "Courier API settings" },
    "courier_logs": { "schema": "object", "description": "API request logs" },
    "hrm": { "schema": "object", "description": "HR module data" },
    "performanceMetrics": { "schema": "performanceMetric", "description": "Employee KPI tracking" },
    "kpiConfigs": { "schema": "object", "description": "KPI weight configurations" },
    "purchaseBatches": { "schema": "purchaseBatch", "description": "Inventory cost batches" },
    "stockLedger": { "schema": "stockLedger", "description": "Historical stock movements" },
    "settings": { "schema": "object", "description": "App settings" }
  }
}
