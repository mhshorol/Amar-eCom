rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'mhshorol@gmail.com');
    }

    function isAdmin() {
       return isSignedIn() && (
         request.auth.token.email == 'mhshorol@gmail.com' ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'staff') == 'admin')
       );
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function hasModulePermission(module) {
      return isVerified() && (
        request.auth.token.email == 'mhshorol@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('active', false) == true && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'staff') == 'admin' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {})[module] == true)
        )
      );
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isVerified();
      allow create: if isOwner(userId) && request.resource.data.get('role', 'staff') == 'staff';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'photoURL', 'lastLogin']));
    }

    match /orders/{id} {
      allow get: if hasModulePermission('orders') || hasModulePermission('pos');
      allow list: if isVerified();
      allow create: if (hasModulePermission('orders') || hasModulePermission('pos'));
      allow update: if (hasModulePermission('orders') || hasModulePermission('pos')) && resource.data.get('status', 'pending') != 'delivered';
      allow delete: if isAdmin();
    }

    match /customers/{id} {
      allow get: if isVerified();
      allow list: if isVerified();
      allow create, update: if hasModulePermission('crm') || hasModulePermission('pos');
    }

    match /products/{id} {
      allow read: if isVerified();
      allow write: if hasModulePermission('inventory');
    }

    match /variants/{id} {
      allow read: if isVerified();
      allow write: if hasModulePermission('inventory');
    }

    match /inventory/{id} {
      allow read: if isVerified();
      allow write: if hasModulePermission('inventory');
    }

    match /activityLogs/{id} {
      allow read: if isAdmin();
      allow create: if isVerified() && request.resource.data.get('userId', '') == request.auth.uid;
    }

    match /rma_requests/{id} {
      allow read, write: if hasModulePermission('orders');
    }

    match /notifications/{id} {
      allow create: if isVerified();
      allow read: if isVerified() && request.auth.uid in resource.data.recipients;
      allow update: if isVerified() && request.auth.uid in resource.data.recipients && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'updatedAt']);
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /health_check/{id} {
      allow read, write: if true;
    }
    
    // Add generic catch-all for other collections used in the app
    match /warehouses/{id} { allow read: if isVerified(); allow write: if hasModulePermission('inventory'); }
    match /categories/{id} { allow read: if isVerified(); allow write: if hasModulePermission('inventory'); }
    match /brands/{id} { allow read: if isVerified(); allow write: if hasModulePermission('inventory'); }
    match /accounts/{id} { allow read: if hasModulePermission('finance'); allow write: if hasModulePermission('finance'); }
    match /transactions/{id} { allow read: if hasModulePermission('finance'); allow create: if isVerified(); allow update, delete: if isAdmin(); }
    match /suppliers/{id} { allow read: if hasModulePermission('suppliers'); allow write: if hasModulePermission('suppliers'); }
    match /stock_transfers/{id} { allow read: if isVerified(); allow write: if hasModulePermission('inventory'); }
    match /purchaseOrders/{id} { allow read, write: if hasModulePermission('suppliers') || hasModulePermission('inventory'); }
    match /supplierPayments/{id} { allow read, write: if hasModulePermission('suppliers') || hasModulePermission('finance'); }
    match /couriers/{id} { allow read, write: if hasModulePermission('logistics'); }
    match /deliveries/{id} { allow read, write: if hasModulePermission('logistics'); }
    match /courier_configs/{id} { allow read: if true; allow write: if isAdmin(); }
    match /courier_logs/{id} { allow read, write: if isAdmin(); }
    match /tasks/{id} { 
      allow read, create, update: if hasModulePermission('tasks');
      allow delete: if isAdmin();
    }
    match /purchaseBatches/{id} { allow read: if isVerified(); allow write: if hasModulePermission('inventory'); }
    match /stockLedger/{id} { allow read: if isVerified(); allow write: if hasModulePermission('inventory'); }
    match /wastage_logs/{id} { allow read: if isVerified(); allow write: if hasModulePermission('inventory'); }
    match /petty_cash/{id} {
      allow read: if isVerified();
      allow write: if hasModulePermission('finance');
    }
    match /performanceMetrics/{id} { allow read: if isVerified(); allow write: if isAdmin(); }
    match /kpiConfigs/{id} { allow read: if isVerified(); allow write: if isAdmin(); }
    
    // HR module collections
    match /employees/{id} { allow read, write: if hasModulePermission('hr'); }
    match /designations/{id} { allow read, write: if hasModulePermission('hr'); }
    match /attendance/{id} { allow read, write: if hasModulePermission('hr'); }
    match /salaryAdvances/{id} { allow read, write: if hasModulePermission('hr'); }
    match /salaryRecords/{id} { allow read, write: if hasModulePermission('hr'); }
  }
}
